# Application Environment
# For local development or deployed-local mode, use NODE_ENV=development
# NODE_ENV=production is only used on Heroku
NODE_ENV=development
PORT=5200

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Hashtag@123
DB_NAME=webauthn_passkey

# For Heroku MySQL, use full connection string:
# DB_HOST=your-heroku-db-host.cleardb.net
# DB_USER=your-heroku-db-user
# DB_PASSWORD=your-heroku-db-password
# DB_NAME=your-heroku-db-name

