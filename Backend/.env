# WebAuthn Configuration (Passkey Settings)
# RP_ID should match your domain (e.g., localhost for local dev, your-heroku-app.herokuapp.com for production)
RP_ID=localhost
RP_NAME=Passkey Testing Lab
ORIGIN=http://localhost:5200

# For Heroku production (uncomment and update when deploying):
# HEROKU_APP_NAME=passkey-testing-lab
# HEROKU_APP_URL=https://passkey-testing-lab-ecc52e0ca9c4.herokuapp.com
# ORIGIN=https://passkey-testing-lab-ecc52e0ca9c4.herokuapp.com
# RP_ID=passkey-testing-lab-ecc52e0ca9c4.herokuapp.com


# Note that the following environment variables are not fully implemented in the current codebase, but are included here for future extensibility and best practices:

# HTTPS/SSL Configuration
# For local development (self-signed certificates):
# Leave these commented out - the server will look for Backend/certs/ by default
# SSL_CERT_PATH=./certs/cert.pem
# SSL_KEY_PATH=./certs/key.pem

# For production with Let's Encrypt:
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Enable HTTPS (0 = HTTP only, 1 = HTTPS)
# HTTPS_ENABLED=0